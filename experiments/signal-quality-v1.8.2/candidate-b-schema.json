{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldmonitor.local/schemas/candidate-b-signal.json",
  "title": "WorldMonitor V1.8.2 Candidate B extraction result",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "shouldCreateSignal",
        "title",
        "extractedSignal",
        "source",
        "originalText",
        "triggerEvent",
        "direction",
        "timeHorizon",
        "tickerResolution",
        "monitoringMetrics",
        "confirmationConditions",
        "invalidationConditions",
        "logicChainAssumptions",
        "qualityScore",
        "needsReview",
        "committeeEligible",
        "committeeRoute",
        "dedupeKey"
      ],
      "properties": {
        "shouldCreateSignal": { "const": true },
        "rejectionReason": { "type": "null" },
        "sourcePostId": { "type": ["string", "null"] },
        "title": { "type": "string", "minLength": 1 },
        "extractedSignal": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "originalText": { "type": "string", "minLength": 1 },
        "triggerEvent": { "type": "string", "minLength": 1 },
        "direction": {
          "enum": ["BULLISH", "BEARISH", "MIXED", "CONDITIONAL", "UNKNOWN"]
        },
        "timeHorizon": { "type": ["string", "null"], "minLength": 1 },
        "tickerResolution": { "$ref": "#/$defs/tickerResolution" },
        "monitoringMetrics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/monitoringMetric" }
        },
        "confirmationConditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/confirmation" }
        },
        "invalidationConditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/invalidation" }
        },
        "logicChainAssumptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "qualityScore": { "type": "integer", "minimum": 0, "maximum": 7 },
        "needsReview": { "type": "boolean" },
        "committeeEligible": { "type": "boolean" },
        "committeeRoute": { "enum": ["AUTO_ENTRY", "MANUAL_QUEUE", "NEEDS_REVIEW"] },
        "dataUnavailableReason": {
          "type": ["string", "null"],
          "enum": [null, "SOURCE_UNAVAILABLE", "AWAITING_EVENT", "MANUAL_VERIFICATION_REQUIRED", "INVALID_TICKER", "UNSUPPORTED_INSTRUMENT"]
        },
        "dedupeKey": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["shouldCreateSignal", "rejectionReason", "committeeEligible", "committeeRoute"],
      "properties": {
        "shouldCreateSignal": { "const": false },
        "rejectionReason": { "type": "string", "minLength": 1 },
        "committeeEligible": { "const": false },
        "committeeRoute": { "const": "REJECTED" }
      },
      "additionalProperties": true
    }
  ],
  "$defs": {
    "tickerResolution": {
      "type": "object",
      "required": ["resolutions", "validatedTickers", "overallStatus", "needsReview", "confidenceThreshold"],
      "properties": {
        "resolutions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["mentionedEntity", "canonicalName", "ticker", "exchange", "instrumentType", "confidence", "evidenceText", "resolutionStatus"],
            "properties": {
              "mentionedEntity": { "type": "string" },
              "canonicalName": { "type": "string" },
              "ticker": { "type": ["string", "null"] },
              "exchange": { "type": ["string", "null"] },
              "instrumentType": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "evidenceText": { "type": "string", "minLength": 1 },
              "resolutionStatus": {
                "enum": ["VALIDATED", "AMBIGUOUS", "PRIVATE_COMPANY", "NON_EQUITY", "UNSUPPORTED", "NEEDS_REVIEW"]
              }
            },
            "additionalProperties": false
          }
        },
        "validatedTickers": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "overallStatus": {
          "enum": ["VALIDATED", "AMBIGUOUS", "PRIVATE_COMPANY", "NON_EQUITY", "UNSUPPORTED", "NEEDS_REVIEW"]
        },
        "needsReview": { "type": "boolean" },
        "reviewReason": { "type": ["string", "null"] },
        "confidenceThreshold": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "monitoringMetric": {
      "type": "object",
      "required": ["metric", "unit", "timeWindow", "sourceType", "executable"],
      "properties": {
        "metric": { "type": "string", "minLength": 1 },
        "unit": { "type": "string", "minLength": 1 },
        "timeWindow": { "type": ["string", "null"], "minLength": 1 },
        "sourceType": { "type": "string", "minLength": 1 },
        "executable": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "confirmation": {
      "type": "object",
      "required": ["metric", "operator", "unit", "timeWindow", "deadline", "sourceType"],
      "properties": {
        "metric": { "type": "string", "minLength": 1 },
        "operator": { "type": "string", "minLength": 1 },
        "threshold": { "type": ["number", "string", "null"] },
        "event": { "type": ["string", "null"] },
        "unit": { "type": "string", "minLength": 1 },
        "timeWindow": { "type": "string", "minLength": 1 },
        "deadline": { "type": "string", "minLength": 1 },
        "sourceType": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["threshold"] },
        { "required": ["event"] }
      ],
      "additionalProperties": true
    },
    "invalidation": {
      "type": "object",
      "required": ["type", "metricOrEvent", "operator", "unit", "deadline", "sourceType", "invalidates", "executable", "manualReviewReason"],
      "properties": {
        "type": { "enum": ["METRIC_BREACH", "EVENT_FAILURE", "ASSUMPTION_BREAK", "TIME_EXPIRY"] },
        "metricOrEvent": { "type": "string", "minLength": 1 },
        "operator": { "type": "string", "minLength": 1 },
        "threshold": { "type": ["number", "string", "null"] },
        "expectedState": { "type": ["string", "null"] },
        "unit": { "type": "string", "minLength": 1 },
        "deadline": { "type": "string", "minLength": 1 },
        "sourceType": { "type": "string", "minLength": 1 },
        "invalidates": { "type": "string", "minLength": 1 },
        "executable": { "type": "boolean" },
        "manualReviewReason": { "type": ["string", "null"] }
      },
      "anyOf": [
        { "required": ["threshold"] },
        { "required": ["expectedState"] }
      ],
      "additionalProperties": false
    }
  }
}
